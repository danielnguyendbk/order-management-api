            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    { \"productName\": \"Mouse\", \"quantity\": 3, \"unitPrice\": 100000 }\n  ],\n  \"totalAmount\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": [
