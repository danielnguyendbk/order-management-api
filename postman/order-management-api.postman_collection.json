            {
              "key": "name",
              "value": "nguyen"
            }
          ]
        }
      }
    },
    {
      "name": "09 - Get Order by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
