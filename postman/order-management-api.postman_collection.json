    },
    {
      "name": "13 - Get Deleted Order (Expect 404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}"
          ]
        }
      }
    }
  ]
}
