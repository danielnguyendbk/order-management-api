{
  "info": {
    "name": "Order Management API - Lab2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection test full flow: health, CRUD, filter status, search name, sort totalAmount, validation totalAmount"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "orderId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Has standardized response format', function () {",
              "  pm.expect(body).to.have.property('success', true);",
              "  pm.expect(body).to.have.property('message');",
              "  pm.expect(body).to.have.property('data');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Create Order (Valid)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"Nguyen Van A\",\n  \"customerEmail\": \"vana@email.com\",\n  \"items\": [\n    { \"productName\": \"Laptop Dell XPS\", \"quantity\": 1, \"unitPrice\": 25000000 },\n    { \"productName\": \"Chuot Logitech\", \"quantity\": 2, \"unitPrice\": 500000 }\n  ],\n  \"totalAmount\": 26000000,\n  \"status\": \"pending\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Create response is standardized', function () {",
              "  pm.expect(body.success).to.eql(true);",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.have.property('_id');",
              "});",
              "pm.collectionVariables.set('orderId', body.data._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Create Order (Invalid totalAmount)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"Test Sai Tong\",\n  \"customerEmail\": \"saitong@email.com\",\n  \"items\": [\n    { \"productName\": \"Ban phim\", \"quantity\": 2, \"unitPrice\": 300000 }\n  ],\n  \"totalAmount\": 1000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 400', function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Validation error format', function () {",
              "  pm.expect(body.success).to.eql(false);",
              "  pm.expect(body).to.have.property('message');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Get All Orders",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
      }
    },
    {
      "name": "05 - Filter by Status (pending)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders?status=pending",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ],
          "query": [
            {
              "key": "status",
              "value": "pending"
            }
          ]
        }
      }
    },
